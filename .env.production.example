# ─── قاعدة البيانات ───────────────────────────────────────────────────────────
# SQLite — المسار الكامل على السيرفر
DATABASE_URL="file:/var/www/bahrna/prisma/production.db"

# ─── NextAuth ─────────────────────────────────────────────────────────────────
# غيّر هذا المفتاح لقيمة عشوائية طويلة (32+ حرف)
NEXTAUTH_SECRET="CHANGE_THIS_TO_A_LONG_RANDOM_STRING_32_CHARS_MIN"
# ضع رابط موقعك الحقيقي هنا
NEXTAUTH_URL="https://bahrnaa.com"

